{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Loom Policy File",
  "description": "Schema for .loom/policies/*.yaml files",
  "type": "object",
  "required": ["rules"],
  "properties": {
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["action", "default"],
        "properties": {
          "action": {
            "type": "string",
            "enum": ["read_file", "write_file", "execute", "read_secret", "install_dependency", "write_memory"]
          },
          "default": {
            "type": "string",
            "enum": ["allow", "deny", "approve"]
          },
          "requires": { "type": "string" },
          "conditions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "path_match": { "type": "string" },
                "command_match": { "type": "string" },
                "alias_match": { "type": "string" },
                "decision": { "type": "string", "enum": ["allow", "deny", "approve"] },
                "reason": { "type": "string" }
              }
            }
          },
          "approval_timeout": { "type": "integer" }
        }
      }
    }
  }
}
