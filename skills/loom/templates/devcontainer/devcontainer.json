{
  "name": "Loom Workspace",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/node:1": { "version": "20" },
    "ghcr.io/devcontainers/features/python:1": { "version": "3.12" }
  },
  "mounts": [
    "source=loom-pip-cache-${devcontainerId},target=/home/vscode/.cache/pip,type=volume",
    "source=loom-npm-cache-${devcontainerId},target=/home/vscode/.npm,type=volume",
    "source=loom-node-modules-${devcontainerId},target=${containerWorkspaceFolder}/node_modules,type=volume"
  ],
  "postCreateCommand": "loom resume || loom init",
  "customizations": {
    "vscode": {
      "extensions": []
    }
  }
}
