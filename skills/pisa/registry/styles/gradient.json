{
  "style_id": "gradient",
  "name": "Gradient Band",
  "version": "1.0.0",
  "description": "Bold accent bands, gradient overlays, high-energy visual impact.",
  "source": {
    "origin": "registry",
    "type": "style"
  },
  "rules": {
    "cards": {
      "bg_pattern": "alternate_dark_light",
      "corner_radius": 10,
      "shadow": true,
      "border": "top",
      "border_thickness": 3
    },
    "title": {
      "alignment": "left",
      "size_multiplier": 1.1,
      "letter_spacing": -0.5
    },
    "accent_bar": {
      "position": "full_width_band",
      "width_pct": 100,
      "thickness": 0
    },
    "spacing": {
      "multiplier": 1.0,
      "card_gap_pct": 2
    },
    "decoration": {
      "geometric_accent": true,
      "top_bar": false,
      "bottom_bar": false,
      "gradient_overlay": true
    }
  }
}