{
  "style_id": "bold",
  "name": "Bold Statement",
  "version": "1.0.0",
  "description": "High contrast, geometric accents, strong visual hierarchy. Titles dominate.",
  "source": {
    "origin": "registry",
    "type": "style"
  },
  "rules": {
    "cards": {
      "bg_pattern": "alternate_dark_accent",
      "corner_radius": 8,
      "shadow": true,
      "border": "top",
      "border_thickness": 4
    },
    "title": {
      "alignment": "left",
      "size_multiplier": 1.2,
      "letter_spacing": -0.5
    },
    "accent_bar": {
      "position": "below_title",
      "width_pct": 12,
      "thickness": 4
    },
    "spacing": {
      "multiplier": 1.0,
      "card_gap_pct": 2
    },
    "decoration": {
      "geometric_accent": true,
      "top_bar": true,
      "bottom_bar": true,
      "gradient_overlay": false
    }
  }
}