{
  "style_id": "minimal",
  "name": "Minimal Elegant",
  "version": "1.0.0",
  "description": "Maximum whitespace, thin borders, restrained accents. Content breathes.",
  "source": {
    "origin": "registry",
    "type": "style"
  },
  "rules": {
    "cards": {
      "bg_pattern": "all_transparent",
      "corner_radius": 0,
      "shadow": false,
      "border": "none",
      "border_thickness": 0
    },
    "title": {
      "alignment": "left",
      "size_multiplier": 1.3,
      "letter_spacing": -1.0
    },
    "accent_bar": {
      "position": "below_title",
      "width_pct": 18,
      "thickness": 2
    },
    "spacing": {
      "multiplier": 1.4,
      "card_gap_pct": 4
    },
    "decoration": {
      "geometric_accent": false,
      "top_bar": false,
      "bottom_bar": false,
      "gradient_overlay": false
    }
  }
}