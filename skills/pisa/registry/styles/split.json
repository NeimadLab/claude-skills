{
  "style_id": "split",
  "name": "Split Block",
  "version": "1.0.0",
  "description": "Two-tone layouts. Accent panel meets dark panel. Strong visual division.",
  "source": {
    "origin": "registry",
    "type": "style"
  },
  "rules": {
    "cards": {
      "bg_pattern": "zone_accent_dark",
      "corner_radius": 0,
      "shadow": false,
      "border": "vertical_separator",
      "border_thickness": 3
    },
    "title": {
      "alignment": "left",
      "size_multiplier": 1.1,
      "letter_spacing": -0.5
    },
    "accent_bar": {
      "position": "none",
      "width_pct": 0,
      "thickness": 0
    },
    "spacing": {
      "multiplier": 1.0,
      "card_gap_pct": 0
    },
    "decoration": {
      "geometric_accent": false,
      "top_bar": false,
      "bottom_bar": false,
      "gradient_overlay": true
    }
  }
}